# ─────────────────────────────────────────────────────────────────
# PowerUp Portal — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Google Service Account ────────────────────────────────────
# Option A: path to a downloaded JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Option B: paste the raw JSON content as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# ── M1 · Client Report Sheet ──────────────────────────────────
# Deployed Web App URL from Google Apps Script
# (Deploy → New deployment → Web app → Anyone → Copy URL)
M1_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_DEPLOYMENT_ID/exec

# Spreadsheet ID containing SCHEME_DATA, BASE_DATA, PF_LEVEL sheets
# (from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
M1_SPREADSHEET_ID=your-m1-spreadsheet-id

# Drive folder ID where M1 saves its output Google Sheets
# (from the URL: drive.google.com/drive/folders/FOLDER_ID)
M1_OUTPUT_FOLDER_ID=your-m1-output-folder-id


# ── M2 · Client Strategy Deck ─────────────────────────────────
# Spreadsheet ID containing M2 data tabs:
#   PF_level, Riskgroup_level, Scheme_level, Lines, Results,
#   Invested_Value_Line, Questionnaire, Scheme_Category
M2_SPREADSHEET_ID=your-m2-spreadsheet-id

# Drive file ID of the M2 Google Slides template
# (converted from "Base Deck - M2 automation.pptx")
M2_TEMPLATE_ID=your-m2-slides-template-file-id

# Drive file ID of the Risk/Reward slides source
# (converted from "Risk_Reward_Slides_Automation.pptx")
M2_RISK_REWARD_TEMPLATE_ID=your-m2-risk-reward-template-file-id

# Drive folder ID where generated M2 decks are saved
M2_OUTPUT_FOLDER_ID=your-m2-output-folder-id


# ── M3 · Portfolio Transition Deck ────────────────────────────
# Spreadsheet ID containing M3 reference data tabs:
#   AUM_31Jan, Powerranking, upside_downside, Rolling_Returns
M3_SPREADSHEET_ID=your-m3-spreadsheet-id

# Drive file ID of the M3 Google Slides template
# (converted from "Template.pptx")
M3_TEMPLATE_ID=your-m3-slides-template-file-id

# Drive folder ID where generated M3 decks are saved
M3_OUTPUT_FOLDER_ID=your-m3-output-folder-id


# ── Data Manager ──────────────────────────────────────────────
# Spreadsheet ID the Data Manager reads/writes.
# Leave blank to default to M2_SPREADSHEET_ID.
DATA_SPREADSHEET_ID=
