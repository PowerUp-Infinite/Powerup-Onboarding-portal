portal/*.pptx
portal/*.png
portal/*.xlsx

# Old automation folders (not needed for deployment)
M1-automation/
M2-automation/
M3-automation/

# Output files
*.pptx
*.xlsx
_backups/

# OS
.DS_Store
Thumbs.db

# Misc
WORKLOG.md
Test data.xlsx
