# Environment and secrets — never commit these
.env
portal/.env
*.secrets.toml
**/secrets.toml
*.json

# Allow .streamlit/config.toml (but not secrets)
!.streamlit/
!.streamlit/config.toml

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Local asset files (now served from Google Drive)
portal/*.pptx
portal/*.png
portal/*.xlsx

# Old automation folders (not needed for deployment)
M1-automation/
M2-automation/
M3-automation/

# Output files
*.pptx
*.xlsx
_backups/

# OS
.DS_Store
Thumbs.db

# Desktop app build artefacts and local credentials
# - dist/ holds both the PyInstaller .exe and the package-windows.bat output
# - build/ is PyInstaller scratch
# - .venv/ is the local Python venv used for development
# - resources/{credentials.json, .env} are bundled at build time but never
#   committed (would leak the service account key)
desktop/dist/
desktop/build/
desktop/.venv/
desktop/resources/credentials.json
desktop/resources/.env

# Misc
WORKLOG.md
Test data.xlsx
